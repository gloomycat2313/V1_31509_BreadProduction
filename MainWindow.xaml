<Window x:Class="V_31509_BreadProduction.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:V_31509_BreadProduction"
        mc:Ignorable="d"
        Title="Хлебобулочные изделия" 
        MinHeight="450" MinWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Label FontSize="12pt"
               HorizontalAlignment="Center"
               VerticalAlignment="Center">Хлебобулочный завод</Label>
        
        <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden"
               Grid.Row="1"/>

        <Grid Panel.ZIndex="-1" Background="LightBlue"/>

    </Grid>
</Window>
