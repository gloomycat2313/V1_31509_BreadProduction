<Page x:Class="V_31509_BreadProduction.Pages.LoginPages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:V_31509_BreadProduction.Pages.LoginPages"
      mc:Ignorable="d" 
      d:DesignHeight="550" d:DesignWidth="800"
      Title="LoginPage">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel  Grid.Column="1" Grid.Row="1"
                     MaxWidth="550">
            <GroupBox Header="Авторизация">
                <StackPanel>
                    <StackPanel>
                        <Label>Логин</Label>
                        <TextBox x:Name="TbxLogin"></TextBox>
                    </StackPanel>
                    <StackPanel>
                        <Label >Пароль</Label>
                        <PasswordBox x:Name="PsbPassword"></PasswordBox>
                    </StackPanel>

                    <Button x:Name="BtnLogin"
                        Click="BtnLogin_Click">Войти</Button>

                </StackPanel>
            </GroupBox >
            <GroupBox Header="Смарт-капча"
                  Grid.Column="1" Grid.Row="1">

                <GroupBox.Resources>
                    <Style TargetType="{x:Type StackPanel}">
                        <Setter Property="Margin" Value="5"/>
                    </Style>
                </GroupBox.Resources>

                <UniformGrid Columns="2">
                    <UniformGrid Columns="2" Rows="2">

                        <UniformGrid.Resources>
                            <Style TargetType="{x:Type Image}">
                                <Setter Property="Width" Value="80"/>
                                <Setter Property="Height" Value="80"/>
                            </Style>
                        </UniformGrid.Resources>

                        <StackPanel>
                            <Label>Фрагмент 1</Label>
                            <Image x:Name="SrcImage1" Source="/Resources/1.png" />
                            <ComboBox x:Name="Cb1"
                                      SelectionChanged="Cb_SelectionChanged">
                                <ComboBoxItem>1</ComboBoxItem>
                                <ComboBoxItem>2</ComboBoxItem>
                                <ComboBoxItem>3</ComboBoxItem>
                                <ComboBoxItem>4</ComboBoxItem>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel>
                            <Label>Фрагмент 2</Label>
                            <Image x:Name="SrcImage2" Source="/Resources/2.png" />
                            <ComboBox x:Name="Cb2"
                                      SelectionChanged="Cb_SelectionChanged">
                                <ComboBoxItem>1</ComboBoxItem>
                                <ComboBoxItem>2</ComboBoxItem>
                                <ComboBoxItem>3</ComboBoxItem>
                                <ComboBoxItem>4</ComboBoxItem>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel>
                            <Label>Фрагмент 3</Label>
                            <Image x:Name="SrcImage3" Source="/Resources/3.png" />
                            <ComboBox x:Name="Cb3"
                                      SelectionChanged="Cb_SelectionChanged">
                                <ComboBoxItem>1</ComboBoxItem>
                                <ComboBoxItem>2</ComboBoxItem>
                                <ComboBoxItem>3</ComboBoxItem>
                                <ComboBoxItem>4</ComboBoxItem>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel>
                            <Label>Фрагмент 4</Label>
                            <Image x:Name="SrcImage4" Source="/Resources/4.png" />
                            <ComboBox x:Name="Cb4"
                                      SelectionChanged="Cb_SelectionChanged">
                                <ComboBoxItem>1</ComboBoxItem>
                                <ComboBoxItem>2</ComboBoxItem>
                                <ComboBoxItem>3</ComboBoxItem>
                                <ComboBoxItem>4</ComboBoxItem>
                            </ComboBox>
                        </StackPanel>
                    </UniformGrid>
                    <UniformGrid Rows="2" Columns="2">
                        <UniformGrid.Resources>
                            <Style TargetType="{x:Type Border}">
                                <Setter Property="BorderBrush" Value="LightGray"/>
                                <Setter Property="BorderThickness" Value="1"/>
                            </Style>
                        </UniformGrid.Resources>

                        <Border>
                            <Image x:Name="TargImg1" Stretch="Fill"/>
                        </Border>
                        <Border>
                            <Image x:Name="TargImg2" Stretch="Fill"/>
                        </Border>
                        <Border>
                            <Image x:Name="TargImg3" Stretch="Fill"/>
                        </Border>
                        <Border>
                            <Image x:Name="TargImg4" Stretch="Fill"/>
                        </Border>
                    </UniformGrid>
                </UniformGrid>
            </GroupBox>
        </StackPanel>
    </Grid>
</Page>
