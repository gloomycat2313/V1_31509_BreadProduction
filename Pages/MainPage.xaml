<Page x:Class="V_31509_BreadProduction.Pages.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:V_31509_BreadProduction.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="MainPage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel LastChildFill="False">
            <Button x:Name="OpenUsers"
                    Click="OpenUsers_Click">Пользователи</Button>
            <Button x:Name="OpenOrders"
                    Click="OpenOrders_Click">Заказы</Button>
            <Button x:Name="Logout" 
                    Click="Logout_Click"
                    DockPanel.Dock="Right">Выйти</Button>
        </DockPanel>

        <Grid Panel.ZIndex="-1" Background="AliceBlue"/>

        <Frame Grid.Row="1" x:Name="MainPageFrame" NavigationUIVisibility="Hidden"/>

    </Grid>
</Page>
