<Page x:Class="V_31509_BreadProduction.Pages.UserPages.UserAddEditPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:V_31509_BreadProduction.Pages.UserPages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="UserAddEditPage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <GroupBox Header="Данные для входа">

            <GroupBox.Resources>
                <Style TargetType="{x:Type StackPanel}">
                    <Setter Property="Margin" Value="0,5,0,0"/>
                </Style>
            </GroupBox.Resources>

            <StackPanel>
                <StackPanel>
                    <Label>Логин</Label>
                    <TextBox Text="{Binding Login}"></TextBox>
                </StackPanel>
                <StackPanel>
                    <Label>Пароль</Label>
                    <PasswordBox x:Name="PsbPassword"></PasswordBox>
                </StackPanel>
                <StackPanel>
                    <Label>Роль</Label>
                    <ComboBox x:Name="CbRoles" SelectedItem="{Binding Role}"
                              DisplayMemberPath="Name">
                    </ComboBox>
                </StackPanel>
                <StackPanel>
                    <CheckBox>Статус блокировки</CheckBox>
                </StackPanel>
            </StackPanel>
        </GroupBox>

        <DockPanel Grid.Row="1" LastChildFill="False"
                   HorizontalAlignment="Center">
            <Button x:Name="AddUser"
                    Click="AddUser_Click">Добавить</Button>
            <Button x:Name="GoBack"
                    Click="GoBack_Click">Назад</Button>
        </DockPanel>
        
        
    </Grid>
</Page>
